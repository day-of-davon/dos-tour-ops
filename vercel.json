{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/intel.js": { "maxDuration": 120 },
    "api/parse-doc.js": { "maxDuration": 60 },
    "api/flights.js": { "maxDuration": 180 },
    "api/production.js": { "maxDuration": 60 },
    "api/lodging-scan.js": { "maxDuration": 180 },
    "api/rideshare-scan.js": { "maxDuration": 180 },
    "api/car-rental-scan.js": { "maxDuration": 180 },
    "api/food-scan.js": { "maxDuration": 180 },
    "api/receipt-url.js": { "maxDuration": 15 },
    "api/comms.js": { "maxDuration": 30 },
    "api/route.js": { "maxDuration": 30 },
    "api/monitoring.js": { "maxDuration": 10 }
  }
}
