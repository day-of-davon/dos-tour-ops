{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/intel.js": { "maxDuration": 120 },
    "api/parse-doc.js": { "maxDuration": 60 },
    "api/flights.js": { "maxDuration": 120 },
    "api/production.js": { "maxDuration": 60 },
    "api/lodging-scan.js": { "maxDuration": 60 },
    "api/comms.js": { "maxDuration": 30 },
    "api/route.js": { "maxDuration": 30 }
  }
}
