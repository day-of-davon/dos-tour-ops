# Supabase — use service key to bypass RLS
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Master Tour Electron app path (default works on macOS)
MT_APP_PATH=/Applications/Master Tour.app/Contents/MacOS/Master Tour

# Tour to target in Master Tour (must match exactly as shown in the app title bar)
MT_TOUR_NAME=Summer 2026

# Team ID for shared DOS storage
DOS_TEAM_ID=dos-bbno-eu-2026
