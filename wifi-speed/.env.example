# wifi-speed — Orbi RBR50 connection
# Copy to wifi-speed/.env or export these before running the CLI.

ORBI_HOST=orbilogin.com      # or your router LAN IP, e.g. 192.168.1.1
ORBI_PORT=5000               # genie SOAP API port (5000 http, 443 https)
ORBI_SCHEME=http             # http or https
ORBI_USER=admin              # router admin username
ORBI_PASSWORD=               # router admin password (required)

# Optional
# ORBI_DATA_DIR=./wifi-speed/data
# ORBI_UI_PORT=8787
# ORBI_TIMEOUT_MS=15000
