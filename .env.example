# ── Supabase (get from supabase.com > project > settings > API) ──────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role key (server-side only, never expose to browser) ────
# Get from supabase.com > project > settings > API > service_role
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Anthropic (get from console.anthropic.com) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App URL (set to your Vercel deployment URL in production) ─────────────────
VITE_APP_URL=http://localhost:3000
