# ── Supabase (get from supabase.com > project > settings > API) ──────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role key (server-side only, never expose to browser) ────
# Get from supabase.com > project > settings > API > service_role
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Anthropic (get from console.anthropic.com) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App URL (set to your Vercel deployment URL in production) ─────────────────
VITE_APP_URL=http://localhost:3000

# ── PostHog product analytics (optional; feeds HYPOTHESES.md kill-dates) ──────
# Leave unset to disable entirely — analytics is a no-op without the key.
# Get the Project API key from posthog.com > project > settings.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry error monitoring (optional; catches prod crashes) ──────────────────
# Leave unset to disable entirely — Sentry is a no-op without the DSN.
# Get the DSN from sentry.io > project > settings > Client Keys (DSN).
VITE_SENTRY_DSN=
